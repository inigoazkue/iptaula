# Abierto sin login por ahora (como el sistema actual). Cuando se integre AD/LDAP,
# basta con poner esto a True y añadir la configuración de REMOTE_AUTH_BACKEND;
# no requiere cambios en el modelo de datos.
LOGIN_REQUIRED=False
# LOGIN_REQUIRED=False solo evita forzar login para VER páginas; sin esto,
# un usuario anónimo sigue sin permiso para leer los modelos por la API
# (403). "*" = todos los modelos visibles sin autenticar, igual de abierto
# que el resto de esta config por ahora.
EXEMPT_VIEW_PERMISSIONS=*
# Necesario para que el panel visual (dashboard/, en otro puerto) pueda leer
# la API desde el navegador. Igual de abierto que LOGIN_REQUIRED=False, no
# añade permisos nuevos, solo permite que otro origen la consulte.
CORS_ORIGIN_ALLOW_ALL=True
SKIP_SUPERUSER=false
